###############################################################################
# resubmit_500ev.sub — Resubmit incomplete jobs with 500 events/job
#
# Replaces:
#   B1 (0-3), B2 (0-3), B3 (0-3) — 4 jobs × 50 000 ev each (no EOS output)
#   S3 job 6                       — 50 000 ev (4 MB file, expected ~8.6 MB)
#
# New split: 500 events/job (100× more jobs, same total events)
#   B1: 400 jobs (ProcIds 0-399) = 200 000 events
#   B2: 400 jobs (ProcIds 0-399) = 200 000 events
#   B3: 400 jobs (ProcIds 0-399) = 200 000 events
#   S3: 100 jobs (ProcIds 10-109) =  50 000 events  [no conflict with done 0-9]
#
# Submit:  condor_submit condor/resubmit_500ev.sub
###############################################################################
universe        = vanilla
executable      = /afs/cern.ch/user/p/pleguina/omtf_hecin_dataset_production/condor/run_job.sh
arguments       = $(Dataset) $(ProcId) $(SkipEvents) $(NumEvents)

output  = /afs/cern.ch/user/p/pleguina/omtf_hecin_dataset_production/logs/full_$(Dataset)_$(ProcId).out
error   = /afs/cern.ch/user/p/pleguina/omtf_hecin_dataset_production/logs/full_$(Dataset)_$(ProcId).err
log     = /afs/cern.ch/user/p/pleguina/omtf_hecin_dataset_production/logs/resubmit_500ev.log

should_transfer_files = NO

request_cpus    = 1
request_memory  = 4000
request_disk    = 5000000

+JobFlavour     = "nextweek"
+AccountingGroup = "group_u_CMS.u_zh.users"
use_x509userproxy = true
x509userproxy    = /afs/cern.ch/user/p/pleguina/private/x509_proxy

